<view class="page">
  <view class="header">
    <text class="eyebrow">city</text>
    <text class="title">{{regionName}}</text>
    <text class="subtitle">{{region.level || 'city'}} / 指标详情</text>
  </view>

  <view wx:if="{{error}}" class="error">{{error}}</view>
  <view wx:if="{{loading}}" class="empty">加载中...</view>

  <block wx:for="{{cards}}" wx:key="indicator.code">
    <view class="panel">
      <text class="panelTitle">{{item.indicator.display_name || item.indicator.name}}</text>
      <text class="secondary">{{item.indicator.description || '暂无指标说明'}}</text>
      <view class="row">
        <text>最新值</text>
        <text class="value">{{item.latest ? item.latest.value : '-'}} {{item.indicator.unit || ''}}</text>
      </view>
      <view class="row">
        <text>最新周期</text>
        <text>{{item.latest ? item.latest.period : '-'}}</text>
      </view>
    </view>
  </block>

  <view wx:if="{{cards.length === 0 && !loading}}" class="empty">暂无城市指标数据</view>
</view>
