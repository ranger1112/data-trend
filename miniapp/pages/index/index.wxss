.page {
  background: #f6f7f9;
  min-height: 100vh;
  padding: 32rpx;
}

.header {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.eyebrow {
  color: #607086;
  font-size: 22rpx;
  font-weight: 800;
}

.title {
  color: #1f2937;
  font-size: 44rpx;
  font-weight: 800;
}

.subtitle,
.secondary {
  color: #6b788a;
  font-size: 24rpx;
}

.error {
  background: #fff0f0;
  border: 1rpx solid #ffc4c4;
  border-radius: 12rpx;
  color: #9b1c1c;
  font-size: 26rpx;
  margin-bottom: 18rpx;
  padding: 20rpx;
}

.summary {
  display: grid;
  gap: 16rpx;
  grid-template-columns: repeat(3, 1fr);
  margin-bottom: 22rpx;
}

.summaryItem,
.select,
.panel {
  background: #ffffff;
  border: 1rpx solid #dce3eb;
  border-radius: 12rpx;
}

.summaryItem {
  padding: 20rpx;
}

.summaryItem text {
  color: #607086;
  display: block;
  font-size: 24rpx;
}

.summaryItem strong {
  color: #145db8;
  display: block;
  font-size: 38rpx;
  margin-top: 6rpx;
}

.toolbar {
  display: grid;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.select,
.search,
.favoriteBtn {
  color: #1f2937;
  font-size: 28rpx;
  min-height: 84rpx;
  line-height: 84rpx;
  padding: 0 24rpx;
}

.favoriteBtn {
  background: #145db8;
  border: 0;
  border-radius: 12rpx;
  color: #ffffff;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  background: #edf5ff;
  border-radius: 999rpx;
  color: #145db8;
  font-size: 24rpx;
  padding: 10rpx 18rpx;
}

.panel {
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.panelTitle {
  color: #1f2937;
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 16rpx;
}

.row {
  align-items: center;
  border-bottom: 1rpx solid #edf1f5;
  display: flex;
  justify-content: space-between;
  min-height: 78rpx;
}

.row:last-child {
  border-bottom: 0;
}

.primary {
  color: #1f2937;
  display: block;
  font-size: 28rpx;
  font-weight: 700;
}

.value {
  color: #145db8;
  font-size: 30rpx;
  font-weight: 800;
}

.barTrack {
  background: #e5ebf2;
  border-radius: 999rpx;
  flex: 1;
  height: 14rpx;
  margin: 0 18rpx;
  overflow: hidden;
}

.bar {
  background: #21a67a;
  border-radius: 999rpx;
  height: 100%;
  min-width: 4rpx;
}

.sectionLabel {
  color: #607086;
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  margin: 18rpx 0 8rpx;
}

.empty {
  color: #6b788a;
  font-size: 28rpx;
  padding: 32rpx 0;
  text-align: center;
}
